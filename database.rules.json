{
  "rules": {

    // ══════════════════════════════════════════════════════════
    //  بيان المزرعة — Firebase Security Rules (Hardened)
    //
    //  السابق: كل الكولكشنز كانت ".read": true / ".write": true للعموم
    //  بالكامل، من غير أي auth — أي حد عنده الـ databaseURL (وهو موجود
    //  بالكود المصدري اللي بيتحمل في متصفح أي زائر) يقدر يقرا ويعدّل
    //  ويمسح بيانات المزرعة كاملة، بما فيها users/pin_hash.
    //
    //  الحل بيعتمد على البنية التحتية اللي firebase.js أصلاً بيعملها:
    //  1. كل جلسة (حتى قبل تسجيل الدخول بالـPIN) بتاخد Firebase
    //     Anonymous Auth token تلقائيًا (_signInAnonymouslyRestOnce)
    //     → auth != null بقى مضمون لأي طلب حقيقي من التطبيق.
    //  2. بعد نجاح الـPIN، signInWithFirebaseAuth() بتربط الجلسة
    //     بهوية Firebase حقيقية خاصة بنفس المستخدم، وتكتب
    //     uid_lookup/{firebaseUid} → {appUserId} عشان الـrules تقدر
    //     تعرف "مين ده" وتجيب الدور بتاعه من users/{appUserId}/role.
    //
    //  إيه اللي اتغيّر هنا:
    //  - كل الكولكشنز بقت محتاجة auth != null كحد أدنى (بتقفل أي طلب
    //    REST مباشر من برا التطبيق من غير ما يعدّي حتى بـAnonymous Auth).
    //  - finance / users / settings: الكتابة بقت مقصورة على admin فقط
    //    (مطابق تمامًا لـROLE_PERMS في firebase.js: supervisor/vet/
    //    worker/visitor كلهم مستبعدين من 'users' و'finance' أصلاً).
    //  - قراءة finance سابت auth != null بس (مش admin-only) لأن
    //    dashboard.html بيحسب ملخص الإيرادات/المصروفات اليومية لكل
    //    الأدوار من غير فحص can('finance') — تقييدها كانت هتكسر
    //    الداشبورد لغير الـadmin.
    //  - uid_lookup: كل مستخدم يقرا/يكتب سطره الخاص بس (مش يقدر
    //    يلعب في mapping حد تاني وينتحل دوره).
    //  - أول تشغيل على قاعدة بيانات فاضية (Users.init() في firebase.js)
    //    لسه شغّال: لو users/ لسه مش موجودة خالص بيسمح بإنشاء أول
    //    admin حتى من غير auth دور admin (مفيش دور أصلاً وقتها).
    //
    //  ملحوظ ومهم — حدود الحل ده:
    //  - الـPIN لسه 4 أرقام (10,000 احتمال) وSHA-256 hash بصيغة salt
    //    معروفة في الكود المصدري نفسه؛ لو حد قدر يقرا users/ (حتى بعد
    //    التقييد ده، auth != null سهل الحصول عليه بنفس الـapiKey
    //    العام) يقدر يجرّب الـ10,000 احتمال offline بسرعة. تقوية
    //    الـPIN نفسه (رقم أطول / rate-limit حقيقي) موضوع منفصل.
    //  - الكتابة على باقي الكولكشنز (animals, health, breeding...) لسه
    //    مسموحة لأي مستخدم auth != null (مش مقيدة بالدور بالكامل زي
    //    ROLE_PERMS) — ده تقليل مخاطرة عملي من غير ما أخاطر أكسر
    //    workflow حقيقي (زي vet بيكتب health, worker بيكتب animals)
    //    من غير اختبار حي على قاعدة البيانات الفعلية. تضييق أدق لاحقًا
    //    لو الفريق عايز دور-بدور enforcement كامل.
    //
    //  ⚠️ قبل النشر: جرّب الـrules دي في Firebase Console > Realtime
    //  Database > Rules > Playground (أو `firebase database:rules
    //  --instance ...`) على الأقل مع سيناريو تسجيل دخول كامل + كل
    //  الأدوار، قبل ما تعمل publish على القاعدة الحقيقية.
    // ══════════════════════════════════════════════════════════

    "animals": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('species') && newData.hasChild('breed') && newData.hasChild('gender')",
        "species": { ".validate": "newData.val() === 'goat' || newData.val() === 'sheep'" },
        "gender":  { ".validate": "newData.val() === 'male' || newData.val() === 'female'" }
      }
    },

    "health": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('animal_tag') && newData.hasChild('diagnosis') && newData.hasChild('date')"
      }
    },

    "vaccinations": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "vaccination_templates": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "breeding": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('female_breed')"
      }
    },

    "production_log": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('type') && newData.hasChild('date') && newData.hasChild('quantity')",
        "type":     { ".validate": "newData.val() === 'milk' || newData.val() === 'wool' || newData.val() === 'weight'" },
        "quantity": { ".validate": "newData.isNumber() && newData.val() > 0" }
      }
    },

    "daily_tasks": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('title') && newData.hasChild('date')",
        "status": { ".validate": "!newData.exists() || newData.val() === 'pending' || newData.val() === 'in_progress' || newData.val() === 'done'" }
      }
    },

    "inventory_meds": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "inventory_feeds": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "inventory_equipment": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "inventory_transactions": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "feed_consumption": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "weight_log": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "weights": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "weight_alerts": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "production_alerts": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "workflow_history": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "notifications": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "activity": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('action') && newData.hasChild('collection')"
      }
    },

    "activity_log": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "!data.exists()"
      }
    },

    // ── Sensitive: Finance — read stays app-wide (dashboard shows
    //    today's income/expense summary to every role, unconditionally),
    //    write restricted to admin only, matching ROLE_PERMS exactly
    //    (supervisor/vet/worker/visitor are never granted 'finance'). ──
    "finance": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(root.child('uid_lookup').child(auth.uid).child('appUserId').val()).child('role').val() === 'admin'",
      "$id": {
        ".validate": "newData.hasChild('type') && newData.hasChild('amount') && newData.hasChild('date')",
        "type":   { ".validate": "newData.val() === 'income' || newData.val() === 'expense'" },
        "amount": { ".validate": "newData.isNumber() && newData.val() > 0" }
      }
    },

    // ── Users: read needed for the PIN-login screen (matches by pin_hash
    //    client-side); write restricted to admin only -- prevents any
    //    signed-in session from granting itself 'role':'admin' or
    //    overwriting another user's pin_hash. The `!data.exists()`
    //    fallback keeps Users.init()'s one-time bootstrap (creates the
    //    very first admin account on a brand-new, empty database) working
    //    even before any admin identity exists yet. ────────────────────
    "users": {
      ".read":  "auth != null",
      ".write": "(auth != null && root.child('users').child(root.child('uid_lookup').child(auth.uid).child('appUserId').val()).child('role').val() === 'admin') || !data.exists()",
      "$uid": {
        ".validate": "newData.hasChild('role') && newData.hasChild('name')"
      }
    },

    // ── uid_lookup: each signed-in identity may only read/write its OWN
    //    mapping entry -- stops one session from remapping another uid
    //    and inheriting/spoofing that user's resolved role elsewhere. ──
    "uid_lookup": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Settings: farm-wide configuration, admin-managed page in the
    //    app (settings.html isn't in any non-admin role's page list). ──
    "settings": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(root.child('uid_lookup').child(auth.uid).child('appUserId').val()).child('role').val() === 'admin'"
    },

    // Note: the old singular "diary_snapshot" path was removed here --
    // dead since the diary history redesign moved to the dated
    // "diary_snapshots" collection below; no code reads or writes it
    // anymore (confirmed empty in production), so it's no longer worth
    // a standing rule. See git history if it ever needs restoring.
    "diary_snapshots": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "login_notifications": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Block everything else not listed ─────────────────────
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
