{
  "rules": {

    // ══════════════════════════════════════════════════════════
    //  بيان المزرعة — Firebase Security Rules (Practical)
    //  التطبيق يستخدم PIN login مخصص (مش Firebase Auth)
    //  لذلك الحماية بتعتمد على:
    //  1. عدم كشف الـ databaseURL للعموم (Vercel env var)
    //  2. منع القراءة الكاملة من غير Authenticated
    //  3. الكتابة متاحة بس عبر الـ URL المعروف للتطبيق
    // ══════════════════════════════════════════════════════════

    // ── Public Read but Restricted Write ─────────────────────
    // القراءة متاحة (التطبيق مش بيبعت auth headers)
    // الكتابة مفتوحة من نفس النطاق — محمية بإخفاء الـ URL

    "animals": {
      ".read": true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('species') && newData.hasChild('breed') && newData.hasChild('gender')",
        "species": { ".validate": "newData.val() === 'goat' || newData.val() === 'sheep'" },
        "gender":  { ".validate": "newData.val() === 'male' || newData.val() === 'female'" }
      }
    },

    "health": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('animal_tag') && newData.hasChild('diagnosis') && newData.hasChild('date')"
      }
    },

    "vaccinations": {
      ".read":  true,
      ".write": true
    },

    "vaccination_templates": {
      ".read":  true,
      ".write": true
    },

    "breeding": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('female_breed')"
      }
    },

    "production_log": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('type') && newData.hasChild('date') && newData.hasChild('quantity')",
        "type":     { ".validate": "newData.val() === 'milk' || newData.val() === 'wool' || newData.val() === 'weight'" },
        "quantity": { ".validate": "newData.isNumber() && newData.val() > 0" }
      }
    },

    "daily_tasks": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('title') && newData.hasChild('date')",
        "status": { ".validate": "!newData.exists() || newData.val() === 'pending' || newData.val() === 'in_progress' || newData.val() === 'done'" }
      }
    },

    "inventory_meds": {
      ".read":  true,
      ".write": true
    },

    "inventory_feeds": {
      ".read":  true,
      ".write": true
    },

    // ── Added: referenced by pages/inventory.js (fbTable mapping for
    //    type 'equip') and animals.html's bulk-reset table list. Was
    //    missing entirely -> every read/write fell through to $other
    //    -> 401, which is the exact error reported. ──────────────────
    "inventory_equipment": {
      ".read":  true,
      ".write": true
    },

    // ── Added: write-once transaction log created by shared.js's
    //    recordInventoryTransaction() (Inventory Transaction Engine
    //    v1.7). Purely additive per its own header comment; was never
    //    added to rules when that feature shipped. ──────────────────
    "inventory_transactions": {
      ".read":  true,
      ".write": true
    },

    "feed_consumption": {
      ".read":  true,
      ".write": true
    },

    "weight_log": {
      ".read":  true,
      ".write": true
    },

    // ── Added: settings.html's _deleteTable('weights') targets this
    //    top-level path, but per DATA_MODEL.md the certified SSOT for
    //    weight is the NESTED animals/{id}/weights, not a top-level
    //    collection -- this path is very likely always empty in the
    //    real database. Included for audit completeness (nothing in
    //    the app should ever 401), but flagged here since the reset
    //    button referencing it may itself be a naming leftover worth
    //    a separate look -- not something this rules-only change
    //    attempts to fix. ────────────────────────────────────────────
    "weights": {
      ".read":  true,
      ".write": true
    },

    // ── Added: the dashboard's Predictive Intelligence Engine reads
    //    these three directly by name. All three were completely
    //    absent from rules -> $other -> 401, matching the reported
    //    console errors exactly. ───────────────────────────────────
    "weight_alerts": {
      ".read":  true,
      ".write": true
    },

    "production_alerts": {
      ".read":  true,
      ".write": true
    },

    "workflow_history": {
      ".read":  true,
      ".write": true
    },

    "notifications": {
      ".read":  true,
      ".write": true
    },

    "activity": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('action') && newData.hasChild('collection')"
      }
    },

    "activity_log": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "!data.exists()"
      }
    },

    // ── Sensitive: Finance — write-only validated ─────────────
    "finance": {
      ".read":  true,
      ".write": true,
      "$id": {
        ".validate": "newData.hasChild('type') && newData.hasChild('amount') && newData.hasChild('date')",
        "type":   { ".validate": "newData.val() === 'income' || newData.val() === 'expense'" },
        "amount": { ".validate": "newData.isNumber() && newData.val() > 0" }
      }
    },

    // ── Users: read needed for login ──────────────────────────
    "users": {
      ".read":  true,
      ".write": true,
      "$uid": {
        ".validate": "newData.hasChild('role') && newData.hasChild('name')"
      }
    },

    // ── Added: firebase.js's own auth bootstrap writes here directly
    //    (fbPut('uid_lookup', _authUid, {appUserId})) to map a
    //    Firebase Anonymous-Auth UID to this app's own user id. This
    //    is internal to the auth-token flow itself -- was missing
    //    from rules, so this specific write was silently failing on
    //    every login (caught by its own best-effort try/catch, so it
    //    never surfaced as a visible error the way the dashboard's
    //    reads did). ────────────────────────────────────────────────
    "uid_lookup": {
      ".read":  true,
      ".write": true
    },

    "settings": {
      ".read":  true,
      ".write": true
    },

    "diary_snapshot": {
      ".read":  true,
      ".write": true
    },

    // ── Added: the Farm Diary history redesign (this session) moved
    //    off the single diary_snapshot object onto a real dated
    //    collection, diary_snapshots/{YYYY-MM-DD}, written by
    //    shared.js's saveDiarySnapshot() and read by
    //    getLatestDiarySnapshot()/getDiarySnapshotByDate()/
    //    getDiarySnapshotsBetweenDates(). The old singular entry
    //    above is left as-is (harmless, matches whatever pre-existing
    //    data may still be there) -- only this new plural collection
    //    was actually missing. ──────────────────────────────────────
    "diary_snapshots": {
      ".read":  true,
      ".write": true
    },

    "login_notifications": {
      ".read":  true,
      ".write": true
    },

    // ── Block everything else not listed ─────────────────────
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
