{
  "rules": {

    // ══════════════════════════════════════════════════════════
    //  بيان المزرعة — Firebase Security Rules (Hardened)
    //  التطبيق يستخدم PIN login مخصص، لكن firebase.js دلوقتي بيضمن
    //  auth != null لأي جلسة (Anonymous Auth تلقائي + ربط حقيقي بعد
    //  نجاح الـPIN). القواعد هنا بترفض أي قراءة/كتابة من غير auth
    //  خالص، وتقصر finance/users/settings على admin فقط للكتابة.
    //
    //  ⚠️ لو رجّعت هذا الملف لنسخة ".read": true / ".write": true
    //  المفتوحة تاريخيًا، تأكد إن ده قرار متعمّد ومتزامن مع القواعد
    //  الفعلية المنشورة على Firebase Console -- رجوع هذا الملف وحده
    //  لا يغيّر أي حاجة على القاعدة الحقيقية المنشورة.
    // ══════════════════════════════════════════════════════════

    "animals": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('species') && newData.hasChild('breed') && newData.hasChild('gender')",
        "species": { ".validate": "newData.val() === 'goat' || newData.val() === 'sheep'" },
        "gender":  { ".validate": "newData.val() === 'male' || newData.val() === 'female'" }
      }
    },

    "health": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('animal_tag') && newData.hasChild('diagnosis') && newData.hasChild('date')"
      }
    },

    "vaccinations": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "vaccination_templates": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "breeding": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('female_breed')"
      }
    },

    "production_log": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('type') && newData.hasChild('date') && newData.hasChild('quantity')",
        "type":     { ".validate": "newData.val() === 'milk' || newData.val() === 'wool' || newData.val() === 'weight'" },
        "quantity": { ".validate": "newData.isNumber() && newData.val() > 0" }
      }
    },

    "daily_tasks": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('title') && newData.hasChild('date')",
        "status": { ".validate": "!newData.exists() || newData.val() === 'pending' || newData.val() === 'in_progress' || newData.val() === 'done'" }
      }
    },

    "inventory_meds": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "inventory_feeds": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Added: referenced by pages/inventory.js (fbTable mapping for
    //    type 'equip') and animals.html's bulk-reset table list. Was
    //    missing entirely -> every read/write fell through to $other
    //    -> 401, which is the exact error reported. ──────────────────
    "inventory_equipment": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Added: write-once transaction log created by shared.js's
    //    recordInventoryTransaction() (Inventory Transaction Engine
    //    v1.7). Purely additive per its own header comment; was never
    //    added to rules when that feature shipped. ──────────────────
    "inventory_transactions": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "feed_consumption": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "weight_log": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Added: settings.html's _deleteTable('weights') targets this
    //    top-level path, but per DATA_MODEL.md the certified SSOT for
    //    weight is the NESTED animals/{id}/weights, not a top-level
    //    collection -- this path is very likely always empty in the
    //    real database. Included for audit completeness (nothing in
    //    the app should ever 401), but flagged here since the reset
    //    button referencing it may itself be a naming leftover worth
    //    a separate look -- not something this rules-only change
    //    attempts to fix. ────────────────────────────────────────────
    "weights": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Added: the dashboard's Predictive Intelligence Engine reads
    //    these three directly by name. All three were completely
    //    absent from rules -> $other -> 401, matching the reported
    //    console errors exactly. ───────────────────────────────────
    "weight_alerts": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "production_alerts": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "workflow_history": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "notifications": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "activity": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChild('action') && newData.hasChild('collection')"
      }
    },

    "activity_log": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "!data.exists()"
      }
    },

    // ── Sensitive: Finance — read stays app-wide (dashboard shows
    //    today's income/expense summary to every role, unconditionally),
    //    write restricted to admin only, matching ROLE_PERMS exactly
    //    (supervisor/vet/worker/visitor are never granted 'finance'). ──
    "finance": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(root.child('uid_lookup').child(auth.uid).child('appUserId').val()).child('role').val() === 'admin'",
      "$id": {
        ".validate": "newData.hasChild('type') && newData.hasChild('amount') && newData.hasChild('date')",
        "type":   { ".validate": "newData.val() === 'income' || newData.val() === 'expense'" },
        "amount": { ".validate": "newData.isNumber() && newData.val() > 0" }
      }
    },

    // ── Users: read needed for the PIN-login screen (matches by pin_hash
    //    client-side); write restricted to admin only -- prevents any
    //    signed-in session from granting itself 'role':'admin' or
    //    overwriting another user's pin_hash. The `!data.exists()`
    //    fallback keeps Users.init()'s one-time bootstrap (creates the
    //    very first admin account on a brand-new, empty database) working
    //    even before any admin identity exists yet. ────────────────────
    "users": {
      ".read":  "auth != null",
      ".write": "(auth != null && root.child('users').child(root.child('uid_lookup').child(auth.uid).child('appUserId').val()).child('role').val() === 'admin') || !data.exists()",
      "$uid": {
        ".validate": "newData.hasChild('role') && newData.hasChild('name')"
      }
    },

    // ── uid_lookup: each signed-in identity may only read/write its OWN
    //    mapping entry -- stops one session from remapping another uid
    //    and inheriting/spoofing that user's resolved role elsewhere.
    //    firebase.js's own auth bootstrap writes here directly
    //    (fbPut('uid_lookup', _authUid, {appUserId})) to map a Firebase
    //    Anonymous-Auth UID to this app's own user id. ─────────────────
    "uid_lookup": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Settings: farm-wide configuration, admin-managed page in the
    //    app (settings.html isn't in any non-admin role's page list). ──
    "settings": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(root.child('uid_lookup').child(auth.uid).child('appUserId').val()).child('role').val() === 'admin'"
    },

    "diary_snapshot": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Added: the Farm Diary history redesign (this session) moved
    //    off the single diary_snapshot object onto a real dated
    //    collection, diary_snapshots/{YYYY-MM-DD}, written by
    //    shared.js's saveDiarySnapshot() and read by
    //    getLatestDiarySnapshot()/getDiarySnapshotByDate()/
    //    getDiarySnapshotsBetweenDates(). The old singular entry
    //    above is left as-is (harmless, matches whatever pre-existing
    //    data may still be there) -- only this new plural collection
    //    was actually missing. ──────────────────────────────────────
    "diary_snapshots": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    "login_notifications": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Block everything else not listed ─────────────────────
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
