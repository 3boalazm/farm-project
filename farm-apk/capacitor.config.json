{
  "appId": "com.bayan.farm",
  "appName": "بيان المزرعة",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "android": {
    "backgroundColor": "#0a0a0a",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0a",
      "androidSplashResourceName": "splash",
      "showSpinner": true,
      "spinnerColor": "#ff6b35"
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a0a"
    }
  }
}